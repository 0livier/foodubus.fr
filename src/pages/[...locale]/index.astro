---
import { render, getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import config, { monolocale } from "$config";
import Time from "$utils/time";
import { canonicalPagePath } from "$utils/canonical-url";
import Base from "$layouts/Base.astro";
import Heatmap from "$components/Heatmap.svelte";
import i18nit from "$i18n";
import { tagSlug } from "$utils/slug";

export async function getStaticPaths() {
	// Create path for each locale, omitting default locale from URL
	return config.i18n.locales.map(locale => ({ params: { locale: config.i18n.defaultLocale === locale ? undefined : locale } }));
}

const { locale = config.i18n.defaultLocale } = Astro.params;

const t = i18nit(locale);

// Get preface content for current locale, sorted by timestamp (latest first)
const prefaces = (
	await getCollection("preface", preface => {
		// Handle single locale setup
		if (monolocale) return true;

		// Extract language and ID from file path structure
		const [language, id] = preface.id.split("/");
		preface.id = id;

		// Filter by current locale
		return language === locale;
	})
).sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

// Get published notes for current locale
const notes = await getCollection("note", note => {
	// Assign type property
	Reflect.set(note, "type", "note");

	// Filter by publication status and locale
	let published = !note.data.draft;
	let localed = monolocale || note.id.split("/")[0] === locale;

	// Filter published notes by current locale
	return published && localed;
});

// Get published jottings for current locale
const jottings = await getCollection("jotting", jotting => {
	// Assign type property
	Reflect.set(jotting, "type", "jotting");

	// Check monolocale setup or extract language to match locale
	let localed = monolocale || jotting.id.split("/")[0] === locale;

	// Filter published notes by current locale
	return !jotting.data.draft && localed;
});

// Combine contents
let items: { id: string; type?: string; data: { timestamp: Date; tags?: string[]; [key: string]: any } }[] = [];

// Determine which sections to include
const sections = config.latest || "*";

// Add contents based on config
if (sections === "*" || sections.includes("note")) items = items.concat(notes);
if (sections === "*" || sections.includes("jotting")) items = items.concat(jottings);

// Get the latest content for display
const latest = items.sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime())[0];

// Spotlight a major text series on homepage
const majorSeries = "Lavande";
const majorText = notes
	.filter(note => note.data.series === majorSeries)
	.sort((a, b) => a.data.timestamp.getTime() - b.data.timestamp.getTime())[0];
const majorTextPath = majorText
	? `/note/${monolocale ? majorText.id : majorText.id.split("/").slice(1).join("/")}`
	: undefined;

// Get the latest preface for display
const preface = prefaces[0];
// Render preface content if available, otherwise use empty object
const { Content } = preface ? await render(preface) : ({} as any);
---

<Base title={t("navigation.home")} {locale}>
	<main class="flex flex-col gap-5 sm:gap-5 grow">
		{
			preface && (
				<section class="flex flex-col">
					<article class="markdown">
						<Content />
					</article>
					<a href={getRelativeLocaleUrl(locale, canonicalPagePath("/preface"))} class="self-end my-2 text-sm text-secondary">
						—— {Time.date.locale(preface.data.timestamp, locale)}
					</a>
				</section>
			)
		}

		{
			majorTextPath && (
				<section class="bg-white rounded-md px-2 py-2 sm:px-1 sm:py-1">
					<div class="grid gap-6 sm:gap-10 md:grid-cols-[220px_1fr] md:items-center">
						<a
								href={getRelativeLocaleUrl(locale, canonicalPagePath(majorTextPath))}
								class="link font-mono text-sm tracking-[0.2em]  mt-2"
							>
							<img
								src="/images/lavande/lavande.png"
								alt="Illustration de la série Lavande"
								class="w-full max-w-[220px] justify-self-center md:justify-self-start"
								loading="lazy"
							/>
						</a>

						<article class="flex flex-col gap-3">
							<p class="font-mono text-xs tracking-[0.25em] text-secondary uppercase">A lire...</p>
							<a
								href={getRelativeLocaleUrl(locale, canonicalPagePath(majorTextPath))}
								class="link font-mono text-sm tracking-[0.2em]  mt-2"
							>
							<h2 class="text-3xl sm:text-4xl font-semibold" style="color: var(--primary-color-light)">{majorSeries}</h2>
								Premier chapitre, Eidolon →
							</a>
						</article>
					</div>
				</section>
			)
		}

		{
			latest && (
				<footer class="flex items-center justify-center flex-wrap-reverse gap-10 sm:gap-5">
					<Heatmap {locale} {notes} {jottings} weeks={20} />

					<blockquote class="grow flex flex-col">
						<h4>{t("home.latest")}</h4>
						<div class="flex flex-col sm:flex-row justify-between gap-1 mt-1">
							<a href={getRelativeLocaleUrl(locale, canonicalPagePath(`/${latest.type}/${monolocale ? latest.id : latest.id.split("/").slice(1).join("/")}`))} class="link">
								{latest.data.series && `${latest.data.series} | `}
								{latest.data.title}
							</a>
							<div class="flex gap-1">
								{latest.data.tags?.map((tag, i) => (
									<>
									{i > 0 ? ", " : ""}
									<a href={getRelativeLocaleUrl(locale, canonicalPagePath(`/tag/${tagSlug(tag)}`))} class="text-remark text-[1rem] link">
										{tag}
									</a>
									</>
								))}
							</div>
						</div>
						<time datetime={latest.data.timestamp.toISOString()} class="text-remark font-mono text-xs">
							{Time.date.locale(latest.data.timestamp, locale)}
						</time>
					</blockquote>
				</footer>
			)
		}
	</main>
</Base>
